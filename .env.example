# ── Waves & Wires ADMIN — Environment Variables ──────────────
# Copy this file to .env (same folder) and fill in your values.
# NEVER commit .env to git.

# Get both from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# OPTIONAL on localhost — only needed for password reset emails.
# On localhost just set it to your local URL or leave it out entirely.
# VITE_SITE_URL=http://localhost:3001
